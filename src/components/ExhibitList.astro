---
const baseUrl = import.meta.env.BASE_URL;

const exhibits = [
  {
    href: `${baseUrl}origin`,
    thumbClass: 'origin',
    title: 'THE ORIGIN:',
    description:
      "The earliest forms of computer data storage and processing. Explore how punch cards encoded data as physical patterns of holes, and how magnetic drums served as the first electronic memory devices before the era of hard drives.",
    icon: `<svg viewBox="0 0 56 40" fill="none"><rect x="1" y="1" width="50" height="36" rx="2" fill="#c8b84a" stroke="#9a8828" stroke-width="1"/><rect x="46" y="1" width="5" height="6" rx="1" fill="#9a8828"/><rect x="4" y="8" width="4" height="4" rx="1" fill="#3a2800"/><rect x="11" y="8" width="4" height="4" rx="1" fill="#3a2800"/><rect x="25" y="8" width="4" height="4" rx="1" fill="#3a2800"/><rect x="4" y="16" width="4" height="4" rx="1" fill="#3a2800"/><rect x="18" y="16" width="4" height="4" rx="1" fill="#3a2800"/><rect x="32" y="16" width="4" height="4" rx="1" fill="#3a2800"/><rect x="11" y="24" width="4" height="4" rx="1" fill="#3a2800"/><rect x="25" y="24" width="4" height="4" rx="1" fill="#3a2800"/><rect x="39" y="24" width="4" height="4" rx="1" fill="#3a2800"/><rect x="4" y="32" width="4" height="4" rx="1" fill="#3a2800"/><rect x="18" y="32" width="4" height="4" rx="1" fill="#3a2800"/></svg>`,
  },
  {
    href: `${baseUrl}disk`,
    thumbClass: 'disk',
    title: 'THE DISK:',
    description:
      "The evolution of magnetic disk storage, from IBM's revolutionary RAMAC 350 in 1956 to today's multi-terabyte hard drives. Discover how spinning platters, magnetic heads, and exponential density improvements defined decades of computing.",
    icon: `<svg viewBox="0 0 56 56" fill="none"><circle cx="28" cy="28" r="25" fill="#1e1e2e" stroke="#555" stroke-width="1.5"/><circle cx="28" cy="28" r="20" fill="none" stroke="#363646" stroke-width="0.8"/><circle cx="28" cy="28" r="14" fill="none" stroke="#2e2e3e" stroke-width="0.8"/><circle cx="28" cy="28" r="8" fill="none" stroke="#262636" stroke-width="0.8"/><circle cx="28" cy="28" r="4" fill="#777" stroke="#aaa" stroke-width="1"/><line x1="28" y1="28" x2="48" y2="10" stroke="#39FF14" stroke-width="2" stroke-linecap="round"/><circle cx="48" cy="10" r="3" fill="#39FF14"/></svg>`,
  },
  {
    href: `${baseUrl}optical`,
    thumbClass: 'optical',
    title: 'THE OPTICAL AGE:',
    description:
      "The shift from magnetic to optical storage — CDs, DVDs, and Blu-ray. See how laser beams read microscopic pits and lands on a reflective disc surface, and explore an interactive encoder that shows how your text becomes light and shadow on a disc track.",
    icon: `<svg viewBox="0 0 56 56" fill="none"><defs><radialGradient id="cardCd" cx="50%" cy="50%" r="50%"><stop offset="0%" stop-color="#fff" stop-opacity="0.9"/><stop offset="35%" stop-color="#ffaaaa"/><stop offset="60%" stop-color="#aaffcc"/><stop offset="85%" stop-color="#aaaaff"/><stop offset="100%" stop-color="#cc88ff"/></radialGradient></defs><circle cx="28" cy="28" r="26" fill="url(#cardCd)" stroke="#bbb" stroke-width="0.5"/><circle cx="28" cy="28" r="5" fill="#ddd" stroke="#bbb" stroke-width="0.8"/></svg>`,
  },
  {
    href: `${baseUrl}flash`,
    thumbClass: 'flash',
    title: 'THE FLASH:',
    description:
      "The revolution of solid-state storage. From NAND flash architecture to the PCIe NVMe protocol, explore how eliminating moving parts allowed storage to become faster, smaller, and more reliable than ever before.",
    icon: `<svg viewBox="0 0 56 40" fill="none"><rect x="2" y="2" width="52" height="36" rx="4" fill="#0a160a" stroke="#39FF14" stroke-width="1"/><rect x="7" y="7" width="42" height="22" rx="2" fill="#060e06" stroke="#122212" stroke-width="0.5"/><rect x="10" y="10" width="11" height="7" rx="1" fill="#122212" stroke="#39FF14" stroke-width="0.5"/><rect x="24" y="10" width="11" height="7" rx="1" fill="#122212" stroke="#39FF14" stroke-width="0.5"/><rect x="10" y="20" width="11" height="7" rx="1" fill="#122212" stroke="#39FF14" stroke-width="0.5"/><rect x="24" y="20" width="11" height="7" rx="1" fill="#122212" stroke="#39FF14" stroke-width="0.5"/><rect x="38" y="10" width="7" height="17" rx="1" fill="#1a0e3a" stroke="#8000FF" stroke-width="0.5"/><rect x="7" y="33" width="3" height="3" rx="0.5" fill="#888"/><rect x="12" y="33" width="3" height="3" rx="0.5" fill="#888"/><rect x="17" y="33" width="3" height="3" rx="0.5" fill="#888"/><rect x="22" y="33" width="3" height="3" rx="0.5" fill="#888"/></svg>`,
  },
  {
    href: `${baseUrl}horizon`,
    thumbClass: 'horizon',
    title: 'THE HORIZON:',
    description:
      "Cloud infrastructure, DNA storage, and the technologies being developed today that may define storage for the next century. From distributed datacenters to encoding data in biological molecules, this is where storage is headed.",
    icon: `<svg viewBox="0 0 56 52" fill="none"><ellipse cx="28" cy="36" rx="20" ry="10" fill="#10003a" stroke="#8000FF" stroke-width="1.5"/><circle cx="21" cy="31" r="9" fill="#10003a" stroke="#8000FF" stroke-width="1.5"/><circle cx="35" cy="29" r="8" fill="#10003a" stroke="#8000FF" stroke-width="1.5"/><circle cx="28" cy="24" r="11" fill="#10003a" stroke="#8000FF" stroke-width="1.5"/><path d="M 20 42 Q 24 39 28 42 Q 32 45 36 42" stroke="#FF00FF" stroke-width="1.2" fill="none" stroke-linecap="round"/><path d="M 20 46 Q 24 43 28 46 Q 32 49 36 46" stroke="#00FFFF" stroke-width="1.2" fill="none" stroke-linecap="round"/></svg>`,
  },
];
---

<section class="exhibits" id="exhibits">
  <div class="section-label">Main Exhibits</div>

  <div class="exhibit-list">
    {exhibits.map((ex) => (
      <a href={ex.href} class="exhibit-card">
        <div class={`exhibit-thumb ${ex.thumbClass}`} set:html={ex.icon} />
        <div>
          <h3 class="exhibit-card-title">{ex.title}</h3>
          <p style="text-align: justify;">{ex.description}</p>
        </div>
        <span class="exhibit-arrow">&rsaquo;</span>
      </a>
    ))}
  </div>
</section>
