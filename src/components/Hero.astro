---
const baseUrl = import.meta.env.BASE_URL;
---

<section class="hero">
  <div class="hero-text">
    <p class="hero-label">CSARCH2 &mdash; DLSU Group 7 [S01]</p>
    <h1 class="glitch-title">FULL CAPACITY:</h1>
    <p class="hero-subtitle">The Evolution of Computer Data Storage</p>
    <p class="hero-tagline" style="text-align: justify;">
      From punch cards to petabytes &mdash; trace the failures, the breakthroughs,
      and the innovations that shaped how the world stores data.
    </p>
    <div class="hero-actions">
      <a href="#exhibits" class="btn btn-primary">Explore Exhibits</a>
      <a href={`${baseUrl}about`} class="btn btn-ghost">About Us &rarr;</a>
    </div>
  </div>

  <div class="hero-visual">
    <svg class="hdd-svg" viewBox="0 0 300 260" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <radialGradient id="platterGrad" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#3a3a52"></stop>
          <stop offset="55%" stop-color="#222235"></stop>
          <stop offset="100%" stop-color="#161624"></stop>
        </radialGradient>
        <radialGradient id="hubGrad" cx="40%" cy="35%" r="60%">
          <stop offset="0%" stop-color="#999"></stop>
          <stop offset="100%" stop-color="#444"></stop>
        </radialGradient>
        <filter id="headGlow" x="-50%" y="-50%" width="200%" height="200%">
          <feGaussianBlur stdDeviation="3" result="blur"></feGaussianBlur>
          <feMerge><feMergeNode in="blur"></feMergeNode><feMergeNode in="SourceGraphic"></feMergeNode></feMerge>
        </filter>
      </defs>

      <rect x="4" y="4" width="292" height="252" rx="10" fill="#13131f" stroke="#38384a" stroke-width="1.5"></rect>
      <rect x="12" y="12" width="276" height="236" rx="7" fill="none" stroke="#2a2a38" stroke-width="0.8"></rect>

      <circle cx="22" cy="22" r="5" fill="#111" stroke="#555" stroke-width="1"></circle>
      <circle cx="278" cy="22" r="5" fill="#111" stroke="#555" stroke-width="1"></circle>
      <circle cx="22" cy="238" r="5" fill="#111" stroke="#555" stroke-width="1"></circle>
      <circle cx="278" cy="238" r="5" fill="#111" stroke="#555" stroke-width="1"></circle>
      <circle cx="22" cy="130" r="4" fill="#111" stroke="#444" stroke-width="0.8"></circle>
      <circle cx="278" cy="130" r="4" fill="#111" stroke="#444" stroke-width="0.8"></circle>

      <circle cx="138" cy="130" r="104" fill="url(#platterGrad)" stroke="#3a3a4a" stroke-width="1"></circle>
      <circle cx="138" cy="130" r="94" fill="none" stroke="rgba(255,255,255,0.035)" stroke-width="1"></circle>
      <circle cx="138" cy="130" r="82" fill="none" stroke="rgba(255,255,255,0.035)" stroke-width="1"></circle>
      <circle cx="138" cy="130" r="70" fill="none" stroke="rgba(255,255,255,0.035)" stroke-width="1"></circle>
      <circle cx="138" cy="130" r="58" fill="none" stroke="rgba(255,255,255,0.035)" stroke-width="1"></circle>
      <circle cx="138" cy="130" r="46" fill="none" stroke="rgba(255,255,255,0.035)" stroke-width="1"></circle>
      <circle cx="138" cy="130" r="34" fill="none" stroke="rgba(255,255,255,0.035)" stroke-width="1"></circle>
      <ellipse cx="110" cy="90" rx="30" ry="12" fill="rgba(255,255,255,0.03)" transform="rotate(-30 110 90)"></ellipse>

      <circle cx="138" cy="130" r="20" fill="url(#hubGrad)" stroke="#777" stroke-width="1.5"></circle>
      <circle cx="138" cy="130" r="8" fill="#2a2a3a" stroke="#555" stroke-width="1"></circle>
      <circle cx="134" cy="126" r="2" fill="rgba(255,255,255,0.3)"></circle>

      <circle cx="266" cy="50" r="15" fill="#1e1e2e" stroke="#4a4a5a" stroke-width="2"></circle>
      <circle cx="266" cy="50" r="7" fill="#333" stroke="#666" stroke-width="1"></circle>

      <g class="hdd-arm-g">
        <polygon points="266,50 258,118 274,118" fill="#1a2a1a" stroke="rgba(57,255,20,0.4)" stroke-width="0.8"></polygon>
        <line x1="266" y1="50" x2="172" y2="118" stroke="#39FF14" stroke-width="2" stroke-linecap="round" opacity="0.85"></line>
        <rect x="164" y="112" width="16" height="9" rx="2.5" fill="#39FF14" filter="url(#headGlow)"></rect>
      </g>

      <rect x="252" y="60" width="28" height="140" rx="2" fill="#0a1a0a" stroke="#1a3a1a" stroke-width="0.5" opacity="0.7"></rect>
      <line x1="258" y1="80" x2="274" y2="80" stroke="#39FF14" stroke-width="0.5" opacity="0.4"></line>
      <line x1="258" y1="95" x2="274" y2="95" stroke="#39FF14" stroke-width="0.5" opacity="0.4"></line>
      <line x1="258" y1="110" x2="274" y2="110" stroke="#39FF14" stroke-width="0.5" opacity="0.4"></line>
      <rect x="257" y="170" width="14" height="10" rx="1" fill="#1a3a1a" stroke="#39FF14" stroke-width="0.5" opacity="0.6"></rect>

      <text x="150" y="248" font-family="'Orbitron',monospace" font-size="7" fill="rgba(170,170,204,0.4)" text-anchor="middle" letter-spacing="2">SEAGATE ST-225 &middot; 20 MB &middot; 1984</text>
    </svg>

    <div class="hdd-spec-tags">
      <span class="spec-tag">Punch Card &bull; 80 col &bull; 1890s</span>
      <span class="spec-tag">DVD &bull; 4.7 GB &bull; 1995</span>
      <span class="spec-tag">NVMe SSD &bull; 7000 MB/s &bull; 2013</span>
    </div>
  </div>
</section>
