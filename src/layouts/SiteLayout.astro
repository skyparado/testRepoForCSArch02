---
const { title = 'Full Capacity', isHome = false } = Astro.props.frontmatter ?? Astro.props;

import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/site.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Orbitron:wght@400;700;900&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <Navbar isHome={isHome} />
    <slot />
    <Footer />
  </body>
</html>
